{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "project_name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "file_list": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "module_responsibilities": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "dependency_order": {
      "type": "array",
      "items": { "type": "string" }
    },
    "entry_file": { "type": "string" },
    "app_object": { "type": "string" },
    "framework": { "const": "fastapi" },
    "database": { "enum": ["postgresql", "sqlite"] },
    "auth": { "enum": ["jwt", "none"] }
  },
  "required": [
    "project_name", "file_list", "module_responsibilities",
    "dependency_order", "entry_file", "app_object", "framework",
    "database", "auth"
  ]
}